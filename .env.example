# =============================================================================
# 密钥填这里：复制本文件为 .env.local（与 package.json 同级），再填写下面两行。
# 线上部署：Vercel → 项目 → Settings → Environment Variables，同名添加变量。
# =============================================================================

# ---------------------------------------------------------------------------
# [必填] OpenAI API Key —— 等号右边粘贴 Key（不要加引号）
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# [必填] Nanobanana Pro API Key —— 等号右边粘贴 Key（不要加引号）
# ---------------------------------------------------------------------------
NANOBANANA_API_KEY=

# ---------------------------------------------------------------------------
# [可选] OpenAI 模型，默认 gpt-4o；若账号支持可改为 gpt-5.4 等
# ---------------------------------------------------------------------------
OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# [可选] T8Star 网关（根地址，不要带路径）
# ---------------------------------------------------------------------------
NANOBANANA_BASE_URL=https://ai.t8star.cn

# ---------------------------------------------------------------------------
# [可选] 生图路径（默认 /v1/images/generations，与 T8Star / ComfyUI 节点一致）
# ---------------------------------------------------------------------------
# NANOBANANA_IMAGE_PATH=/v1/images/generations

# ---------------------------------------------------------------------------
# [可选] 模型名（默认 nano-banana-2）
# ---------------------------------------------------------------------------
# NANOBANANA_MODEL=nano-banana-2
